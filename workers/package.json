{
  "name": "richschool-dashboard-workers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":          "wrangler dev",
    "deploy":       "wrangler deploy",
    "db:create":    "wrangler d1 create richschool-storage-history",
    "db:init":      "wrangler d1 execute richschool-storage-history --remote --file=./schema.sql",
    "db:init:local":"wrangler d1 execute richschool-storage-history --local  --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "typescript": "^5.5.3",
    "wrangler": "^3.0.0"
  }
}
