# NAS 저장소 정보 연동 설정
# 이 파일을 복사해 .env.local로 저장한 뒤 값을 채워 주세요.
#
#   cp .env.local.example .env.local
#
# 이 값들은 서버(Next.js API Route)에서만 사용되며, 브라우저에 노출되지 않습니다.
# .env.local은 .gitignore에 포함되어 있어 Git에 커밋되지 않습니다.

# ── NAS 접속 정보 ──────────────────────────────────────────────────────────

# DSM IP 또는 호스트명 (기본값: 192.168.1.136)
NAS_HOST=192.168.1.136

# DSM HTTPS 포트 (기본값: 5001)
NAS_PORT=5001

# DSM 로그인 계정 이름
NAS_USER=your_dsm_username

# DSM 로그인 비밀번호
NAS_PASSWORD=your_dsm_password

# ── Cloudflare Workers 연동 (1단계 마이그레이션 완료 후 설정) ───────────────
#
# 설정하면:
#   - /api/storage-history → Cloudflare D1에서 조회
#   - npm run push-to-cf → NAS 사용량을 D1으로 전송 (cron 등록 권장)
#   - 페이지 방문 시 로컬 JSON 기록은 비활성화됨
#
# 설정하지 않으면:
#   - /api/storage-history → 로컬 data/storage-history.json에서 조회
#   - 페이지 방문 시 자동으로 로컬 JSON 기록 (기존 동작 유지)
#
# workers/ 디렉터리의 README.md 를 보고 D1 생성 및 Workers 배포 후 입력하세요.

# Workers 배포 URL — 수집기(push-to-cloudflare.ts)가 데이터를 전송할 때 사용
# CF_WORKERS_URL=https://richschool-dashboard-api.xxxx.workers.dev

# Workers Secret 에 등록한 API Key (wrangler secret put CF_INGEST_API_KEY)
# CF_INGEST_API_KEY=your_secret_api_key

# 브라우저에서 Workers API를 직접 호출하는 URL (NEXT_PUBLIC_ = 클라이언트 번들에 포함)
# 로컬 개발 시 주석 처리 → Next.js 로컬 API 라우트를 사용합니다.
# Cloudflare Pages 배포 시 Pages 환경변수로 설정하세요 (NEXT_EXPORT=true 와 함께).
# NEXT_PUBLIC_CF_WORKERS_URL=https://richschool-dashboard-api.xxxx.workers.dev
